{
	"name": "plain",
	"version": "0.1.0",
	"description": "An open journal — experiences, lessons, poetry, and the occasional bit of tech.",
	"license": "MIT",
	"private": true,
	"packageManager": "pnpm@11.6.0",
	"scripts": {
		"dev": "astro dev",
		"start": "astro dev",
		"build": "astro check && astro build",
		"preview": "astro preview",
		"lint": "biome lint .",
		"format": "pnpm run format:code && pnpm run format:imports",
		"format:code": "biome format . --write && prettier -w \"**/*\" \"!**/*.{md,mdx}\" --ignore-unknown --cache",
		"format:imports": "biome check --formatter-enabled=false --write",
		"check": "astro check"
	},
	"dependencies": {
		"@astrojs/mdx": "6.0.3",
		"@astrojs/rss": "4.0.18",
		"@astrojs/sitemap": "3.7.3",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/jetbrains-mono": "^5.2.8",
		"@fontsource-variable/newsreader": "^5.2.10",
		"@playform/compress": "^0.2.3",
		"astro": "6.4.6",
		"astro-expressive-code": "^0.41.7",
		"astro-robots-txt": "^1.0.0",
		"astro-seo-schema": "^5.2.0",
		"astro-webmanifest": "^1.0.0",
		"hastscript": "^9.0.1",
		"katex": "^0.16.45",
		"mdast-util-directive": "^3.1.0",
		"mdast-util-to-markdown": "^2.1.2",
		"mdast-util-to-string": "^4.0.0",
		"rehype-external-links": "^3.0.0",
		"rehype-katex": "^7.0.1",
		"remark-directive": "^4.0.0",
		"remark-math": "^6.0.0",
		"satori": "0.15.2",
		"satori-html": "^0.3.2",
		"schema-dts": "^1.1.5",
		"sharp": "^0.34.5",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.1.0"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@biomejs/biome": "^2.4.15",
		"@iconify-json/mdi": "^1.2.3",
		"@resvg/resvg-js": "^2.6.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/hast": "^3.0.4",
		"@types/mdast": "^4.0.4",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"reading-time": "^1.5.0",
		"rehype-unwrap-images": "^1.0.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^5.9.3"
	}
}
