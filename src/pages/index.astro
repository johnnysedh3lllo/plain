---
import { getAllPosts, getPostSortDate, sortMDByDate } from "@/data/post";
import PageLayout from "@/layouts/Base.astro";
import { siteConfig } from "@/site-config";
import { formatRailDate } from "@/utils/date";
import { absoluteUrl, withBase } from "@/utils/path";
import { Schema } from "astro-seo-schema";

const allPosts = await getAllPosts();
const allPostsByDate = sortMDByDate(allPosts);
// Keep the home page roughly one viewport tall no matter how many
// writings exist — everything else lives behind the "See all" link.
const TIMELINE_LIMIT = 3;
const timelinePosts = allPostsByDate.slice(0, TIMELINE_LIMIT);
const featured = timelinePosts[0];
const rest = timelinePosts.slice(1);
const archiveCount = allPosts.length;

// Quotes take over the hero when configured; the first one is the
// build-time text so the page never renders empty, then the inline
// script re-rolls it on every load.
const heroQuotes = siteConfig.heroQuotes ?? [];
const firstQuote = heroQuotes[0];

const siteUrl = (path: string) => absoluteUrl(path, Astro.site);
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: "Home",
				item: siteUrl("/"),
			},
			{
				"@type": "ListItem",
				position: 2,
				name: "About",
				item: siteUrl("/about"),
			},
			{
				"@type": "ListItem",
				position: 3,
				name: "Writings",
				item: siteUrl("/writings"),
			},
		],
	}}
/>

<PageLayout meta={{ title: "Home", description: siteConfig.description }}>
	<section class="hero">
		{
			firstQuote ? (
				<blockquote class="hero-quote">
					<p id="hero-quote-text">{firstQuote.text}</p>
					<footer id="hero-quote-author">{firstQuote.author ? `— ${firstQuote.author}` : ""}</footer>
				</blockquote>
			) : (
				<p>{siteConfig.description}</p>
			)
		}
		{heroQuotes.length > 1 && (
			<script is:inline define:vars={{ heroQuotes }}>
				const q = heroQuotes[Math.floor(Math.random() * heroQuotes.length)];
				const text = document.getElementById("hero-quote-text");
				const author = document.getElementById("hero-quote-author");
				if (text) text.textContent = q.text;
				if (author) author.textContent = q.author ? `— ${q.author}` : "";
			</script>
		)}
	</section>

	<section class="writing" aria-labelledby="writing-label">
		<div class="section-label" id="writing-label">Writings</div>
		<div class="timeline">
			{
				featured && (
					<a
						class="post featured"
						data-astro-prefetch
						href={withBase(`/writings/${featured.id}/`)}
						style="--i: 0"
					>
						<div class="post-rail">
							<time class="post-date" datetime={getPostSortDate(featured).toISOString()}>
								{formatRailDate(getPostSortDate(featured))}
							</time>
							<span class="post-dot" aria-hidden="true" />
						</div>
						<div class="post-body">
							<h2 class="post-title">{featured.data.title}</h2>
							<p class="post-excerpt">{featured.data.description}</p>
						</div>
					</a>
				)
			}

			{
				rest.map((p, idx) => (
					<a
						class="post"
						data-astro-prefetch
						href={withBase(`/writings/${p.id}/`)}
						style={`--i: ${idx + 1}`}
					>
						<div class="post-rail">
							<time class="post-date" datetime={getPostSortDate(p).toISOString()}>
								{formatRailDate(getPostSortDate(p))}
							</time>
							<span class="post-dot" aria-hidden="true" />
						</div>
						<div class="post-body">
							<h3 class="post-title">{p.data.title}</h3>
							<p class="post-preview">{p.data.description}</p>
						</div>
					</a>
				))
			}

			{archiveCount > TIMELINE_LIMIT && (
				<div class="archive-link" style={`--i: ${rest.length + 1}`}>
					<a data-astro-prefetch href={withBase("/writings/")}>
						See all {archiveCount} {archiveCount === 1 ? "writing" : "writings"} →
					</a>
				</div>
			)}
		</div>
	</section>
</PageLayout>

<style>
	/* ---------- Hero ---------- */
	.hero {
		margin-bottom: 88px;
	}
	.hero p {
		font-style: italic;
		font-size: 19.5px;
		line-height: 1.65;
		color: hsl(var(--theme-text));
		margin: 0 0 22px;
		max-width: 60ch;
		text-wrap: pretty;
		white-space: pre-line;
	}
	.hero-quote {
		margin: 0;
		padding: 4px 0 4px 22px;
		border-left: 2px solid hsl(var(--theme-accent));
		max-width: 60ch;
	}
	.hero-quote p {
		margin: 0 0 12px;
	}
	.hero-quote footer {
		font-family: var(--font-serif);
		font-style: normal;
		font-size: 15.5px;
		color: hsl(var(--theme-text-muted));
	}
	.hero-quote footer:empty {
		display: none;
	}
	/* ---------- Writing timeline ---------- */
	.writing {
		margin-bottom: 96px;
	}
	/* ---------- Featured post ---------- */
	.post.featured .post-body {
		padding-bottom: 56px;
	}
	.post.featured .post-title {
		font-size: 30px;
		line-height: 1.14;
		margin-bottom: 14px;
		letter-spacing: -0.02em;
	}
	.post.featured .post-excerpt {
		font-size: 18px;
		line-height: 1.62;
		color: hsl(var(--theme-text-muted));
		margin: 0 0 16px;
		max-width: 58ch;
		word-wrap: break-word;
		overflow-wrap: anywhere;
	}
	/* The latest entry's dot is always filled with the accent. */
	.post.featured .post-dot,
	.post.featured:hover .post-dot {
		--rail-dot-size: 11px;
		background: hsl(var(--theme-accent));
		border-color: hsl(var(--theme-accent));
	}

	.archive-link {
		grid-column: 2;
		margin-top: 8px;
		font-family: var(--font-sans);
		font-size: 13.5px;
		color: hsl(var(--theme-text) / 0.72);
	}
	.archive-link a {
		display: inline-block;
		padding: 6px 0;
		color: hsl(var(--theme-text-muted));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition:
			color 0.2s ease,
			text-decoration-color 0.2s ease;
	}
	.archive-link a:hover {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
	}

	.archive-link a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	@media (max-width: 720px) {
		.hero {
			margin-bottom: 64px;
		}
		.hero p {
			font-size: 18px;
		}
		.post.featured .post-rail {
			display: none;
		}
		.post.featured .post-body {
			padding-bottom: 24px;
			border-bottom: 1px solid var(--hairline);
			margin-bottom: 4px;
		}
		.post.featured .post-title {
			font-size: 22px;
			line-height: 1.2;
			letter-spacing: -0.015em;
			margin-bottom: 10px;
		}
		.post.featured .post-excerpt {
			font-size: 15.5px;
			line-height: 1.55;
			margin: 0 0 10px;
		}
		.archive-link {
			margin-top: 0;
		}
	}

	@media (max-width: 420px) {
		.hero {
			margin-bottom: 48px;
		}
		.hero p {
			font-size: 17px;
		}
		.writing {
			margin-bottom: 64px;
		}
		.post.featured .post-title {
			font-size: 17px;
		}
		.post.featured .post-excerpt {
			font-size: 15px;
		}
	}
</style>
