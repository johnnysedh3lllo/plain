---
import { showcase } from "@/data/showcase";
import { menuLinks, siteConfig } from "@/site-config";
import { withBase } from "@/utils/path";
import ThemeToggle from "../ThemeToggle.astro";

const url = new URL(Astro.request.url);
const wordmark = siteConfig.title;

const visibleMenuLinks = menuLinks.filter((link) => {
	if (link.path === "/showcase/" && showcase.length === 0) return false;
	return true;
});

const isActive = (path: string) => {
	const target = withBase(path);
	if (path === "/") return url.pathname === target;
	return url.pathname === target || url.pathname.startsWith(target);
};
---

<header class="site-header" id="main-header">
	<a href={withBase("/")} class="wordmark" aria-label={`${wordmark} — home`}>
		<span class="dot" aria-hidden="true"></span>
	</a>
	<div class="header-right">
		<nav class="nav" aria-label="Primary">
			{
				visibleMenuLinks.map((link) => (
					<a
						aria-current={isActive(link.path) ? "page" : false}
						class:list={[{ active: isActive(link.path) }]}
						data-astro-prefetch
						href={withBase(link.path)}
					>
						{link.title}
					</a>
				))
			}
		</nav>
		<ThemeToggle />
	</div>
</header>

<style>
	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 72px;
	}
	.wordmark {
		display: inline-flex;
		align-items: center;
		color: hsl(var(--theme-text));
		transition: color 0.2s ease;
	}
	.wordmark .dot {
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: currentColor;
		transition: background-color 0.2s ease;
	}
	.wordmark:hover {
		color: hsl(var(--theme-accent));
	}
	.wordmark:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 4px;
		border-radius: 50%;
	}
	.header-right {
		display: flex;
		align-items: baseline;
		gap: 22px;
	}
	.nav {
		display: flex;
		align-items: baseline;
		gap: 22px;
		font-family: var(--font-sans);
		font-size: 13.5px;
		color: hsl(var(--theme-text) / 0.72);
	}
	.nav a {
		display: inline-block;
		position: relative;
		padding-bottom: 3px;
		transition: color 0.2s ease;
	}
	/* Indicator overhangs the text slightly so the underline isn't abrupt. */
	.nav a::after {
		content: "";
		position: absolute;
		left: -3px;
		right: -3px;
		bottom: 0;
		height: 1px;
		background: transparent;
	}
	.nav a:hover {
		color: hsl(var(--theme-accent));
	}
	.nav a.active {
		color: hsl(var(--theme-text));
	}
	.nav a.active::after {
		background: hsl(var(--theme-accent));
	}

	@media (max-width: 720px) {
		.site-header {
			margin-bottom: 36px;
			display: grid;
			grid-template-columns: 1fr auto;
			grid-template-areas:
				"wordmark theme"
				"nav nav";
			align-items: center;
			column-gap: 14px;
			row-gap: 14px;
		}
		.wordmark { grid-area: wordmark; }
		.header-right { display: contents; }
		.theme-toggle { grid-area: theme; justify-self: end; }
		.nav {
			grid-area: nav;
			gap: 22px;
			font-size: 13px;
			flex-wrap: wrap;
			justify-content: flex-start;
		}
		.nav a {
			/* Add top tap padding; desktop rule keeps the indicator space below. */
			padding-top: 6px;
		}
	}

	@media (max-width: 420px) {
		.site-header {
			margin-bottom: 28px;
			row-gap: 12px;
		}
		.nav {
			gap: 18px;
			font-size: 12.5px;
		}
	}
</style>
